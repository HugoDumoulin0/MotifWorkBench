# Plot CA#
#-----------------------------------#
#
#General plot#
bmp(filename=paste("graphs/", var_name, "_AFC_1.bmp", sep=""),#
	width=2048, height=2048, res=200)#
fviz_ca_col(AFC,#
	shape.col=16,#
	labelsize=4,#
	repel=T,#
	col.col="black") +#
	theme_classic()#
dev.off()
source("setup.R")
