plot_ca_columns <- function(AFC,#
                            shape.col = 16,#
                            labelsize = 4,#
                            repel = TRUE,#
                            col.col = "black") {#
  fviz_ca_col(AFC,#
              shape.col = shape.col,#
              labelsize = labelsize,#
              repel = repel,#
              col.col = col.col) +#
    theme_classic()#
}
plot_ca_columns(AFC)
