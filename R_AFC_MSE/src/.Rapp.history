create_AFC_plot <- function(AFC) {#
  # Get the name of the AFC object as a string#
  var_name <- deparse(substitute(AFC))#
  # Construct the output filename#
  filename <- paste("../graphs/", var_name, "_AFC_1.bmp", sep = "")#
  # Open the BMP device with fixed dimensions and resolution#
  bmp(filename = filename, width = 2048, height = 2048, res = 200)#
  # Generate the plot with fixed settings and classic theme#
  plot_obj <- fviz_ca_col(AFC,#
                          shape.col = 16,#
                          labelsize = 4,#
                          repel = TRUE,#
                          col.col = "black") +#
              theme_classic()#
  # Render the plot to the file and close the device#
  print(plot_obj)#
  dev.off()#
}
create_AFC_plot(AFC)
create_AFC_plot <- function(AFC) {#
  # Get the name of the AFC object as a string#
  # var_name <- deparse(substitute(AFC))#
  # Construct the output filename#
  filename <- paste("../graphs/", var_name, "_AFC_1.bmp", sep = "")#
  # Open the BMP device with fixed dimensions and resolution#
  bmp(filename = filename, width = 2048, height = 2048, res = 200)#
  # Generate the plot with fixed settings and classic theme#
  plot_obj <- fviz_ca_col(AFC,#
                          shape.col = 16,#
                          labelsize = 4,#
                          repel = TRUE,#
                          col.col = "black") +#
              theme_classic()#
  # Render the plot to the file and close the device#
  print(plot_obj)#
  dev.off()#
}
create_AFC_plot(AFC)
AFC_plot_cos2 <- function(AFC){#
  filename <- paste("../graphs/", var_name, "_AFC_cos2.bmp", sep = "")#
  bmp(filename = filename, width = 2048, height = 2048, res = 200)#
  plot_obj <- fviz_ca_col(AFC,#
  	col.col = "cos2",#
  	shape.col=16,#
  	labelsize=4,#
  	repel=T,#
  	gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07")) +#
  	theme_classic() +#
  	guides(colour = guide_colourbar(position = "inside")) +#
  	theme(legend.margin = margin(0, 0, 0, 0),#
  		legend.position.inside = c(0.01, 1),#
  		legend.justification.top = "left",#
  		legend.justification.left = "top",#
  		legend.justification.bottom = "left",#
  		legend.justification.inside = c(0, 1),#
  		legend.location = "plot",#
  		plot.title.position = "plot")#
  print(plot_obj)#
  dev.o
AFC_plot_cos2(AFC)
